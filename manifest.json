{
  "id": "com.harborclient.plugins.json-validator",
  "name": "JSON Schema Validator",
  "author": "HarborClient",
  "version": "1.0.7",
  "categories": [
    "requests",
    "response"
  ],
  "summary": "Attach JSON Schemas to requests and validate response bodies against them with path-level error details.",
  "screenshots": [
    "https://raw.githubusercontent.com/harborclient/plugin-json-validator/main/screenshot.png"
  ],
  "engines": {
    "harborclient": ">=1.8.4"
  },
  "renderer": "dist/renderer.js",
  "permissions": [
    "ui",
    "storage"
  ],
  "contributes": {
    "sidebarSections": [
      {
        "id": "schemas",
        "title": "JSON Schemas"
      }
    ],
    "modals": [
      {
        "id": "schema-editor",
        "title": "Add JSON Schema"
      }
    ],
    "requestTabs": [
      {
        "id": "schema",
        "title": "JSON Schema"
      }
    ],
    "responseTabs": [
      {
        "id": "validation",
        "title": "JSON Validation"
      }
    ]
  }
}
